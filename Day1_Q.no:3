//Write a program to Calculate sum of first N natural numbers.
#include <stdio.h>
int main()
{
   int n,sum=0;
   printf("Enter n number: ");
   scanf("%d",&n);

   while(n!=0)
   {  
      sum+=n;
      n--;
   }

 printf("Sum of n number: %d",sum);
 return 0;
}



//Write a program to Print multiplication table of a given number.
#include <stdio.h>
int main()
{
   int n,i=1,table=0;
   printf("Enter n number: ");
   scanf("%d",&n);

   while(i<=10)
   {  
      table=n*i;
      printf("%d*%d=%d\n",n,i,table);
      i++;
   }

 
 return 0;
}


